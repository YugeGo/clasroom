# 山财空教室 AI 狙击手 — 环境变量配置
# 复制此文件为 .env 后修改

# ─── 数据库 ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/campus_rooms

# ─── DeepSeek API（核心） ───
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ─── Redis（可选，用于爬虫Cookie缓存） ───
REDIS_URL=redis://localhost:6379/0

# ─── 教务系统爬虫（可选） ───
EDU_SYSTEM_TYPE=zhengfang
EDU_BASE_URL=http://jwxt.example.edu.cn
EDU_USERNAME=
EDU_PASSWORD=

# ─── 验证码（爬虫用，可选） ───
CAPTCHA_SOLVER=local
